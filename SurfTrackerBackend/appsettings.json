{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER;Database=SurfTracker;Trusted_Connection=True;TrustServerCertificate=True;"
  },
  "AWS": {
    "Cognito": {
      "Region": "YOUR_REGION",
      "UserPoolId": "YOUR_USER_POOL_ID"
    }
  },
  "AllowedOrigins": [
    "YOUR_PRODUCTION_ORIGIN"
  ]
}
